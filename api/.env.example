NODE_ENV=development
JWT_SECRET=your-secret-here
DB_PATH=./data/hermes.sqlite
# Normally driven by ~/.hermes_client/.env (API_PORT / CLIENT_PORT). Listed
# here for reference.
PORT=18889
# --- CORS ---
# Hermes Client is a single-user local app that you typically reach from
# multiple devices on your LAN / Tailscale, so the default policy is
# "allow every origin". Uncomment the two lines below to lock it down to
# a strict allowlist.
# ALLOWED_DOMAIN=http://localhost:18888,http://my-host.tail-net.ts.net:18888
# HERMES_STRICT_CORS=1
# --- API public URL ---
# Optional fallback used when the API can't read `Host` from the
# request (server-to-server callers). Normal browser traffic always
# uses the request host so upload URLs match wherever the client is.
# API_PUBLIC_URL=http://localhost:18889
# --- Hermes integration ---
# Override the hermes binary used for chat/profile/session commands.
# HERMES_BIN=/usr/local/bin/hermes
# Override the hermes home directory (defaults to ~/.hermes).
# HERMES_HOME=
# Override where uploaded files are stored on disk.
# HERMES_CLIENT_UPLOADS_DIR=
